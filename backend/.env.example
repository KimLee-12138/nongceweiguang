# 鍚庣杩愯鐜锛坉evelopment/test/production锛?
ENV=development

# MySQL 杩炴帴涓诧紙绀轰緥锛歮ysql+pymysql://user:pass@127.0.0.1:3306/ncwg?charset=utf8mb4锛?
MYSQL_DSN=mysql+pymysql://root:password@127.0.0.1:3306/ncwg?charset=utf8mb4

# 鐢熶骇蹇呴』瑕嗙洊涓洪潪榛樿鍊?
JWT_SECRET_KEY=dev-insecure-change-me

# 鍏佽鐨勫墠绔?Origin锛圕ookie 閴存潈蹇呴』绮剧‘鐧藉悕鍗曪紱澶氫釜鐢ㄨ嫳鏂囬€楀彿鍒嗛殧锛?# 鏈湴寮€鍙戦粯璁ゅ缓璁粺涓€浣跨敤 http://127.0.0.1:5173
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173

# 鍙嶅悜浠ｇ悊杞彂澶达紙鎸夐儴缃查渶瑕侊級
TRUST_PROXY_HEADERS=false

# 鍚姩鏃跺箓绛夎ˉ榻?auth 琛ㄧ己鍒楋紙create_all 涓嶄細 ALTER 鏃ц〃锛夈€傜敓浜ц嫢鐢ㄦ墜宸ヨ縼绉诲彲璁句负 false
SCHEMA_AUTO_PATCH=true

# 澶栭儴鑳藉姏锛堟湭閰嶇疆鏃剁浉鍏宠兘鍔涢檷绾э級
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
